local rs = game:GetService("ReplicatedStorage")
local plr = game.Players.LocalPlayer

local targetService = rs.Knit.Knit.Services:FindFirstChild(plr:GetAttribute("Moveset").."Service")
if not targetService then return end 
local rem = targetService.RE.Activated

local hookActive = false
local oldMetaHook = nil
local function enableHook()
    if hookActive then return end
    if not oldMetaHook then
        oldMetaHook = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            local args = { ... }

            if hookActive and self == rem and method == "FireServer" then
                if args[1] == false then
                    args[1] = "Down"
                    return oldMetaHook(self, unpack(args))
                end
            end
            return oldMetaHook(self, ...)
        end)
    end
    hookActive = true
end
local function disableHook()
    hookActive = false
end
local AutoDownslam = {
    Enable = enableHook,
    Disable = disableHook,
    IsEnabled = function() return hookActive end
}

return AutoDownslam
