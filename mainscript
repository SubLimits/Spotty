local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

repeat task.wait() until Players.LocalPlayer:FindFirstChild("PlayerGui")
repeat task.wait() until Players.LocalPlayer.PlayerGui:FindFirstChild("Main")

local mainGui = game.Players.LocalPlayer.PlayerGui.Main
local movesetFrame = mainGui.Moveset
local player = Players.LocalPlayer

local reversalRedButton = nil
local activeAnimationTrack = nil

local function createReversalRedSkill()
    if movesetFrame:FindFirstChild("Reversal Red") then
        movesetFrame["Reversal Red"]:Destroy()
    end
    
    local template = movesetFrame["Cursed Strikes"]:Clone()
    
    template.Name = "Reversal Red"
    template.ItemName.Text = "Reversal Red"
    template.LayoutOrder = 5
    
    for _, descendant in pairs(template:GetDescendants()) do
        if descendant:IsA("TextLabel") or descendant:IsA("TextButton") then
            if descendant.Text == "1" then
                descendant.Text = "5"
            end
        end
    end
    
    local positionOffset = movesetFrame["Manji Kick"].Position.Y.Offset + 100
    template.Position = UDim2.new(movesetFrame["Cursed Strikes"].Position.X.Scale, 
                                  movesetFrame["Cursed Strikes"].Position.X.Offset,
                                  0, positionOffset)
    
    template.Visible = true
    template.Parent = movesetFrame
    
    reversalRedButton = template
    return template
end

createReversalRedSkill()

local function playReversalRedAnimation()
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    if activeAnimationTrack then
        activeAnimationTrack:Stop()
        activeAnimationTrack = nil
    end
    
    local animation = Instance.new("Animation")
    animation.AnimationId = "rbxassetid://137654778575373"
    
    activeAnimationTrack = humanoid:LoadAnimation(animation)
    activeAnimationTrack:Play()
    
    task.delay(2, function()
        if activeAnimationTrack then
            activeAnimationTrack:Stop()
            activeAnimationTrack = nil
        end
    end)
end

local function setupButtonConnections()
    if not reversalRedButton then return end
    
    local clickDetector = reversalRedButton:FindFirstChildOfClass("TextButton")
    if clickDetector then
        for _, connection in pairs(getconnections(clickDetector.MouseButton1Click)) do
            connection:Disconnect()
        end
        
        clickDetector.MouseButton1Click:Connect(function()
            playReversalRedAnimation()
        end)
    end
end

setupButtonConnections()

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Five or input.KeyCode == Enum.KeyCode.KeypadFive then
        if reversalRedButton and reversalRedButton.Visible then
            playReversalRedAnimation()
        end
    end
end)

player.CharacterAdded:Connect(function(character)
    task.wait(0.5)
    
    if not reversalRedButton or not reversalRedButton.Parent then
        createReversalRedSkill()
        setupButtonConnections()
    end
    
    if activeAnimationTrack then
        activeAnimationTrack:Stop()
        activeAnimationTrack = nil
    end
end)

player.CharacterRemoving:Connect(function()
    if activeAnimationTrack then
        activeAnimationTrack:Stop()
        activeAnimationTrack = nil
    end
end)
