local S = game:GetService
local RS, P = S("RunService"), S("Players").LocalPlayer
local Chars = workspace:WaitForChild("Characters")
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/Blissful4992/ESPs/main/UniversalSkeleton.lua"))()

local NAME = "Dummy"
local Skeletons = {}

local function addSkeleton(m)
	if not (m and m:IsA("Model")) then return end
	
	local player = nil
	for _, p in ipairs(game.Players:GetPlayers()) do
		if p.Character == m then
			player = p
			break
		end
	end
	
	if not player then return end
	
	for _, skel in ipairs(Skeletons) do
		if skel.Player == player then
			return
		end
	end

	local skeleton = Library:NewSkeleton(player, true)
	table.insert(Skeletons, skeleton)
end

local function watch(m)
	addSkeleton(m)
	coroutine.wrap(function()
		while m.Parent do 
			addSkeleton(m) 
			task.wait(1) 
		end
	end)()
end

local function check()
	local d = Chars:FindFirstChild(NAME)
	if d then watch(d) end
end

Chars.ChildAdded:Connect(function(c)
	if c.Name == NAME then watch(c) end
end)

Chars.ChildRemoved:Connect(function(c)
	for i, skeleton in ipairs(Skeletons) do
		if skeleton.Player.Character == c then
			skeleton:Remove()
			table.remove(Skeletons, i)
			break
		end
	end
end)

check()
